# === DamuBala API - Environment Variables ===
# Copy this file to .env and fill in real values

# Server
PORT=4000
NODE_ENV=development

# MongoDB connection string (MongoDB Atlas recommended for production)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/damubala

# JWT secret (use a strong random string in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS - set to your frontend production URL (comma-separated for multiple)
# Example: https://damu-bala.vercel.app
CORS_ORIGIN=http://localhost:3000

# OpenAI API key (for AI recommendations and reports)
OPENAI_API_KEY=sk-your-openai-api-key

# Telegram Bot token (get from @BotFather on Telegram)
# Leave empty to disable the Telegram bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token